{
  "builds": [
    { "src": "api.php", "use": "vercel-php@0.6.2" },
    { "src": "admin.php", "use": "vercel-php@0.6.2" },
    { "src": "admin_bagasi.php", "use": "vercel-php@0.6.2" },
    { "src": "admin_charter_create.php", "use": "vercel-php@0.6.2" },
    { "src": "login.php", "use": "vercel-php@0.6.2" },
    { "src": "logout.php", "use": "vercel-php@0.6.2" },
    { "src": "index.php", "use": "vercel-php@0.6.2" },
    { "src": "admin/ajax.php", "use": "vercel-php@0.6.2" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/views/.*", "dest": "/index.php" },
    { "src": "/(index\\.html)?", "dest": "/index.php" },
    { "src": "/admin_bagasi\\.php", "dest": "/admin_bagasi.php" },
    { "src": "/admin_charter_create\\.php", "dest": "/admin_charter_create.php" },
    { "src": "/admin/ajax\\.php(.*)", "dest": "/admin/ajax.php$1" },
    { "src": "/admin", "dest": "/admin.php" },
    { "src": "/login", "dest": "/login.php" },
    { "src": "/logout", "dest": "/logout.php" }
  ]
}
