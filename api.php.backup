<?php
// api.php — simple REST endpoints for Hiace Booking (PostgreSQL/PDO version)
// Compatible with the provided frontend index.html

// Error reporting - disable in production
if (getenv('APP_ENV') === 'production') {
    ini_set('display_errors', 0);
    ini_set('display_startup_errors', 0);
    error_reporting(0);
} else {
    ini_set('display_errors', 1);
    ini_set('display_startup_errors', 1);
    error_reporting(E_ALL);
}

// ----- CORS (restrict in production) -----
$allowed_origins = [
    'http://localhost',
    'http://127.0.0.1',
    'https://seat.multibus.id',  // Add your production domain
];
$origin = $_SERVER['HTTP_ORIGIN'] ?? '';
if (in_array($origin, $allowed_origins)) {
    header("Access-Control-Allow-Origin: $origin");
} elseif (getenv('APP_ENV') !== 'production') {
    // Allow all origins in development only
    header("Access-Control-Allow-Origin: *");
}
header('Access-Control-Allow-Credentials: true');
header('Access-Control-Allow-Methods: GET, POST, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type, X-Requested-With');
if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(204);
    exit;
}
header('Content-Type: application/json; charset=utf-8');

// ----- Database connection -----
require_once 'config/db.php';

// Lazy table creation for critical tables used in booking
$conn->exec("CREATE TABLE IF NOT EXISTS bookings (
    id SERIAL PRIMARY KEY,
    rute VARCHAR(100) NOT NULL,
    tanggal DATE NOT NULL,
    jam TIME NOT NULL,
    unit INT DEFAULT 1,
    seat VARCHAR(20) NOT NULL,
    name VARCHAR(255) NOT NULL,
    phone VARCHAR(50) NOT NULL,
    pickup_point VARCHAR(255),
    pembayaran VARCHAR(50) DEFAULT 'Belum Lunas',
    status VARCHAR(20) DEFAULT 'active',
    segment_id INT DEFAULT 0,
    price NUMERIC(15,2) DEFAULT 0,
    discount NUMERIC(15,2) DEFAULT 0,
    created_at TIMESTAMP DEFAULT NOW()
)");

$conn->exec("CREATE TABLE IF NOT EXISTS customers (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    phone VARCHAR(50) NOT NULL UNIQUE,
    address TEXT,
    pickup_point VARCHAR(255),
    created_at TIMESTAMP DEFAULT NOW()
)");

// ----- helpers -----
function json_ok($payload = [])
{
    echo json_encode(array_merge(['success' => true], $payload));
    exit;
}
function json_err($msg = 'error', $extra = [])
{
    echo json_encode(array_merge(['success' => false, 'error' => $msg], $extra));
    exit;
}
function is_valid_date($d)
{
    return is_string($d) && preg_match('/^\d{4}-\d{2}-\d{2}$/', $d) && strtotime($d) !== false;
}
function is_valid_time($t)
{
    return is_string($t) && preg_match('/^\d{2}:\d{2}$/', $t);
}

// ----- simple routing -----
$method = $_SERVER['REQUEST_METHOD'];
$action = $_GET['action'] ?? null;
if ($method === 'GET') {
    if ($action === 'getRoutes') {
        $res = $conn->query("SELECT name FROM routes ORDER BY id");
        $out = [];
        while ($r = $res->fetch())
            $out[] = $r['name'];
        json_ok(['routes' => $out]);
    }

    if ($action === 'getCharterRoutes') {
        $res = $conn->query("SELECT id, name, origin, destination, duration, rental_price FROM master_carter ORDER BY name");
        $out = [];
        while ($r = $res->fetch())
            $out[] = $r;
        json_ok(['routes' => $out]);
    }

    if ($action === 'getSegments') {
        $routeName = $_GET['route_name'] ?? '';
        if ($routeName) {
            $stmt = $conn->prepare("SELECT s.id, s.rute, s.harga FROM segments s JOIN routes r ON s.route_id = r.id WHERE r.name=? ORDER BY s.rute");
            $stmt->execute([$routeName]);
        } else {
            $stmt = $conn->query("SELECT id, rute, harga FROM segments ORDER BY rute");
        }
        $out = [];
        while ($r = $stmt->fetch())
            $out[] = $r;
        json_ok(['segments' => $out]);
    }

    if ($action === 'getSegmentPrice') {
        $id = intval($_GET['id'] ?? 0);
        $stmt = $conn->prepare("SELECT harga FROM segments WHERE id=? LIMIT 1");
        $stmt->execute([$id]);
        $res = $stmt->fetch();
        json_ok(['price' => $res ? floatval($res['harga']) : 0]);
    }

    if ($action === 'getRoutesByDate') {
        $tanggal = $_GET['tanggal'] ?? '';
        if (!is_valid_date($tanggal))
            json_err('invalid_date');

        // Get day of week (0=Sunday, 6=Saturday)
        $dow = (int) date('w', strtotime($tanggal));

        // Get unique routes that have schedules on this day
        $stmt = $conn->prepare("SELECT DISTINCT s.rute FROM schedules s WHERE s.dow = ? ORDER BY s.rute");
        $stmt->execute([$dow]);
        $out = [];
        while ($r = $stmt->fetch())
            $out[] = $r['rute'];
        json_ok(['routes' => $out]);
    }

    if ($action === 'getSchedules') {
        $rute = $_GET['rute'] ?? '';
        $tanggal = $_GET['tanggal'] ?? '';
        if (!$rute || !is_valid_date($tanggal))
            json_err('invalid_params');
        $dow = (int) date('w', strtotime($tanggal)); // 0..6
        // Join with units table to get kapasitas and layout when unit_id is set
        $stmt = $conn->prepare("SELECT s.jam, s.units, s.seats, s.layout, s.unit_id, u.kapasitas, u.nopol, u.layout AS unit_layout FROM schedules s LEFT JOIN units u ON s.unit_id = u.id WHERE s.rute=? AND s.dow=? ORDER BY s.jam");
        $stmt->execute([$rute, $dow]);
        $out = [];
        while ($r = $stmt->fetch()) {
            // Prioritize schedule's seat count. If 0, fallback to unit capacity.
            $seatCount = intval($r['seats']);
            if ($seatCount <= 0 && $r['unit_id'] && $r['kapasitas']) {
                $seatCount = intval($r['kapasitas']);
            }

            // Always use layout from the linked unit (synced approach)
            $layoutData = [];
            if ($r['unit_id'] && $r['unit_layout']) {
                $layoutData = json_decode($r['unit_layout'], true);
            }
            if (!is_array($layoutData))
                $layoutData = [];

            $out[] = [
                'jam' => substr($r['jam'], 0, 5),
                'units' => intval($r['units']),
                'seats' => $seatCount,
                'layout' => $layoutData,
                'unit_id' => intval($r['unit_id'] ?? 0),
                'nopol' => $r['nopol'] ?? ''
            ];
        }
        json_ok(['schedules' => $out]);
    }

    if ($action === 'getBookedSeatsDetail') {
        $rute = $_GET['rute'] ?? '';
        $tanggal = $_GET['tanggal'] ?? '';
        $jam = $_GET['jam'] ?? '';
        $unit = isset($_GET['unit']) ? intval($_GET['unit']) : 1;
        if (!$rute || !preg_match('/^\d{4}-\d{2}-\d{2}$/', $tanggal) || !preg_match('/^\d{2}:\d{2}$/', $jam)) {
            echo json_encode(['success' => false, 'error' => 'invalid_params']);
            exit;
        }
        $stmt = $conn->prepare("SELECT b.seat, b.name, b.phone, b.pembayaran, b.pickup_point, b.price, b.discount, s.rute AS segment_name FROM bookings b LEFT JOIN segments s ON b.segment_id = s.id WHERE b.rute=? AND b.tanggal=? AND b.jam=? AND b.unit=? AND b.status!='canceled'");
        $stmt->execute([$rute, $tanggal, $jam, $unit]);
        $rows = [];
        while ($r = $stmt->fetch()) {
            $rows[(string) $r['seat']] = [
                'name' => $r['name'],
                'phone' => $r['phone'],
                'pembayaran' => $r['pembayaran'],
                'pickup_point' => $r['pickup_point'],
                'segment_name' => $r['segment_name'],
                'price' => floatval($r['price']),
                'discount' => floatval($r['discount'])
            ];
        }
        echo json_encode(['success' => true, 'details' => $rows]);
        exit;
    }


    if ($action === 'searchCustomers') {
        $q = trim($_GET['q'] ?? '');
        if ($q === '')
            json_ok(['customers' => []]);
        $like = '%' . $q . '%';
        $stmt = $conn->prepare("SELECT name,phone,pickup_point,address FROM customers WHERE name LIKE ? OR phone LIKE ? ORDER BY name LIMIT 20");
        $stmt->execute([$like, $like]);
        $out = [];
        while ($r = $stmt->fetch())
            $out[] = $r;
        json_ok(['customers' => $out]);
    }

    if ($action === 'getUnits') {
        $res = $conn->query("SELECT id, nopol, merek, type, kapasitas FROM units WHERE status='Aktif' ORDER BY nopol");
        $out = [];
        while ($r = $res->fetch()) {
            $out[] = $r;
        }
        json_ok(['units' => $out]);
    }

    if ($action === 'getDrivers') {
        $res = $conn->query("SELECT id, nama, phone FROM drivers ORDER BY nama");
        $out = [];
        while ($r = $res->fetch()) {
            $out[] = $r;
        }
        json_ok(['drivers' => $out]);
    }

    if ($action === 'getLuggageServices') {
        $res = $conn->query("SELECT id, name, price FROM luggage_services ORDER BY price ASC");
        $out = [];
        while ($r = $res->fetch()) {
            $out[] = $r;
        }
        json_ok(['services' => $out]);
    }

    // unknown GET action
    json_err('unknown_action');
}

// ----- POST REQUESTS -----

// 1. Submit New Charter Route (from Index)
if ($method === 'POST' && $action === 'addCharterRoute') {
    $raw = file_get_contents('php://input');
    $data = json_decode($raw, true);
    if (!is_array($data))
        json_err('invalid_json');

    $origin = strtoupper(trim($data['origin'] ?? ''));
    $destination = strtoupper(trim($data['destination'] ?? ''));
    $duration = trim($data['duration'] ?? 'Regular');
    $rental_price = floatval($data['rental_price'] ?? 0);
    $bop_price = floatval($data['bop_price'] ?? 0);
    $notes = trim($data['notes'] ?? '');

    if (!$origin || !$destination || !$rental_price) {
        json_err('missing_fields');
    }

    $name = $origin . ' - ' . $destination;

    $stmt = $conn->prepare("INSERT INTO master_carter (name, origin, destination, duration, rental_price, bop_price, notes) VALUES (?, ?, ?, ?, ?, ?, ?)");
    if (!$stmt)
        json_err('db_prepare_error');

    $stmt->execute([$name, $origin, $destination, $duration, $rental_price, $bop_price, $notes]);
    $route_id = $conn->lastInsertId();
    json_ok(['message' => 'Charter route added', 'route_id' => $route_id]);
}

// 2. Submit Charter Booking
if ($method === 'POST' && $action === 'submitCharter') {
    // Read JSON input
    $raw = file_get_contents('php://input');
    $data = json_decode($raw, true);
    if (!is_array($data))
        json_err('invalid_json');

    $name = strtoupper(trim($data['name'] ?? ''));
    $company = strtoupper(trim($data['company_name'] ?? ''));
    $phone = trim($data['phone'] ?? '');
    $start_date = trim($data['start_date'] ?? '');
    $end_date = trim($data['end_date'] ?? '');
    $departure_time = trim($data['departure_time'] ?? '');
    $pickup = trim($data['pickup_point'] ?? '');
    $drop = trim($data['drop_point'] ?? '');
    $unit_id = intval($data['unit_id'] ?? 0);
    $driver = trim($data['driver_name'] ?? '');
    $price = floatval($data['price'] ?? 0);
    $layanan = trim($data['layanan'] ?? 'Regular');
    $bop_price = floatval($data['bop_price'] ?? 0);

    if (!$name || !$start_date || !$end_date || !$unit_id) {
        json_err('missing_fields');
    }

    // Check if company_name column exists, if not add it (Auto-migration)
    if (!db_column_exists($conn, 'charters', 'company_name')) {
        $conn->exec("ALTER TABLE charters ADD COLUMN company_name VARCHAR(255)");
    }

    // Insert Charter (do not save to customers table)
    $stmt = $conn->prepare("INSERT INTO charters (name, company_name, phone, start_date, end_date, departure_time, pickup_point, drop_point, unit_id, driver_name, price, layanan, bop_price, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW())");
    if (!$stmt) {
        json_err('db_prepare_error');
    }
    $stmt->execute([$name, $company, $phone, $start_date, $end_date, $departure_time, $pickup, $drop, $unit_id, $driver, $price, $layanan, $bop_price]);

    json_ok(['message' => 'Charter saved successfully']);
}

// 3. Submit Luggage Shipment
if ($method === 'POST' && $action === 'submitLuggage') {
    $raw = file_get_contents('php://input');
    $data = json_decode($raw, true);
    if (!is_array($data))
        json_err('invalid_json');

    $sender_name = strtoupper(trim($data['sender_name'] ?? ''));
    $sender_phone = trim($data['sender_phone'] ?? '');
    $sender_address = trim($data['sender_address'] ?? '');
    $receiver_name = strtoupper(trim($data['receiver_name'] ?? ''));
    $receiver_phone = trim($data['receiver_phone'] ?? '');
    $receiver_address = trim($data['receiver_address'] ?? '');
    $service_id = intval($data['service_id'] ?? 0);
    $quantity = max(1, intval($data['quantity'] ?? 1));
    $notes = trim($data['notes'] ?? '');
    $price = floatval($data['price'] ?? 0);

    if (!$sender_name || !$sender_phone || !$receiver_name || !$receiver_phone || !$service_id) {
        json_err('missing_fields');
    }

    $stmt = $conn->prepare("INSERT INTO luggages (sender_name, sender_phone, sender_address, receiver_name, receiver_phone, receiver_address, service_id, quantity, notes, price, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW())");
    if (!$stmt)
        json_err('db_prepare_error');

    $stmt->execute([$sender_name, $sender_phone, $sender_address, $receiver_name, $receiver_phone, $receiver_address, $service_id, $quantity, $notes, $price]);

    json_ok(['message' => 'Luggage shipment saved successfully']);
}

// Regular Booking
$raw = file_get_contents('php://input');
$data = json_decode($raw, true);
if (!is_array($data))
    json_err('invalid_json');

$required = ['rute', 'tanggal', 'jam', 'seats', 'name', 'phone'];
foreach ($required as $k)
    if (!isset($data[$k]) || $data[$k] === '')
        json_err('invalid_payload', ['missing' => $k]);

$rute = trim($data['rute']);
$tanggal = trim($data['tanggal']);
$jam = trim($data['jam']);
$unit = isset($data['unit']) ? intval($data['unit']) : 1;
$name = strtoupper(trim($data['name']));
$phone = trim($data['phone']);
$phone = preg_replace('/\D/', '', $phone);
if (substr($phone, 0, 2) === '62')
    $phone = '0' . substr($phone, 2);
if (substr($phone, 0, 1) === '8')
    $phone = '0' . $phone;
if (strlen($phone) > 13)
    $phone = substr($phone, 0, 13);
$pickup_point = trim($data['pickup_point'] ?? '');
$address = trim($data['address'] ?? '');
$pembayaran = trim($data['pembayaran'] ?? 'Belum Lunas');
$seats = $data['seats'];
$segment_id = isset($data['segment_id']) ? intval($data['segment_id']) : 0;
$discount = isset($data['discount']) ? floatval($data['discount']) : 0;
$price = 0;

if ($segment_id > 0) {
    $stmtS = $conn->prepare("SELECT harga FROM segments WHERE id=? LIMIT 1");
    $stmtS->execute([$segment_id]);
    $resS = $stmtS->fetch();
    if ($resS) {
        $price = floatval($resS['harga']);
    }
}
if (!is_array($seats) || count($seats) === 0)
    json_err('no_seats');

if (!is_valid_date($tanggal))
    json_err('invalid_date_format');
if (!is_valid_time($jam))
    json_err('invalid_time_format');
// sanitize seats (numbers or strings)
$seats = array_values(array_unique(array_map('strval', $seats)));
$numSeats = count($seats);
$discountPerSeat = ($numSeats > 0) ? ($discount / $numSeats) : 0;

// Check conflict phone vs Name
// If phone exists but name is different -> Reject
$stmtC = $conn->prepare("SELECT name FROM customers WHERE phone=? LIMIT 1");
$stmtC->execute([$phone]);
$rowC = $stmtC->fetch();
if ($rowC) {
    if (strtolower(trim($rowC['name'])) !== strtolower($name)) {
        json_err('phone_conflict', [
            'msg' => 'Nomor HP sudah terdaftar atas nama: ' . $rowC['name'] . '. Harap gunakan nama yang sesuai atau nomor HP lain.'
        ]);
    }
}

// Basic seat number validation (1..8)
foreach ($seats as $s) {
    if (!preg_match('/^\d+$/', $s))
        json_err('invalid_seat');
    $n = intval($s);
    if ($n < 1 || $n > 50) { // allow higher in case of non-standard seats
    }
}

// Acquire lock via transaction
$conn->beginTransaction();

try {
    // 1) check conflicts
    $placeholders = implode(',', array_fill(0, count($seats), '?'));
    $sql = "SELECT seat FROM bookings WHERE rute=? AND tanggal=? AND jam=? AND unit=? AND status!='canceled' AND seat IN ($placeholders) FOR UPDATE";
    $stmt = $conn->prepare($sql);
    $bind_params = array_merge([$rute, $tanggal, $jam, $unit], $seats);
    $stmt->execute($bind_params);
    $conflict = [];
    while ($r = $stmt->fetch())
        $conflict[] = (string) $r['seat'];

    if (!empty($conflict)) {
        $conn->rollBack();
        json_err('conflict', ['conflict' => array_values(array_unique($conflict))]);
    }

    // 2) insert bookings rows
    $insert_stmt = $conn->prepare("INSERT INTO bookings (rute,tanggal,jam,unit,seat,name,phone,pickup_point,pembayaran,status,created_at,segment_id,price,discount) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'active', NOW(), ?, ?, ?)");

    foreach ($seats as $s) {
        $seatStr = (string) $s;
        try {
            $insert_stmt->execute([$rute, $tanggal, $jam, $unit, $seatStr, $name, $phone, $pickup_point, $pembayaran, $segment_id, $price, $discountPerSeat]);
        } catch (PDOException $e) {
            // Check for unique constraint violation (PostgreSQL SQLSTATE 23505)
            if ($e->getCode() == '23505') {
                $conflict[] = $seatStr;
            } else {
                throw $e;
            }
        }
    }

    if (!empty($conflict)) {
        $conn->rollBack();
        json_err('conflict', ['conflict' => array_values(array_unique($conflict))]);
    }

    // 3) ensure customer exists: insert or update pickup_point and address
    $stmt_c = $conn->prepare("INSERT INTO customers (name,phone,pickup_point,address) VALUES (?,?,?,?) ON CONFLICT (phone) DO UPDATE SET pickup_point=EXCLUDED.pickup_point, address=EXCLUDED.address");
    $stmt_c->execute([$name, $phone, $pickup_point, $address]);

    $conn->commit();
    json_ok(['added' => count($seats)]);
} catch (Exception $ex) {
    $conn->rollBack();
    $msg = $ex->getMessage();
    json_err('exception', ['detail' => $msg]);
}
