# Environment Configuration
# Copy this file to .env for local development, or set the same values in hosting env vars.
# This project now reads .env / .env.local automatically on local PHP.

# Application Environment
APP_ENV=local

# Database Configuration (Supabase PostgreSQL / pooler recommended)
DATABASE_URL=postgresql://postgres.xxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
